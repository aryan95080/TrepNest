<% layout("/layouts/boilerplate") %>

<section class="min-h-screen flex items-center justify-center bg-gray-100 px-4 py-12">

  <div class="w-full max-w-md bg-white rounded-2xl shadow-xl p-6 sm:p-8">

    <!-- Heading -->
    <h1 class="text-2xl sm:text-3xl font-bold text-center text-gray-800 mb-6">
      Create Your TripNest Account
    </h1>

    <form action="/signup" method="POST" class="space-y-5" novalidate>

      <!-- Username -->
      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-1">
          Username
        </label>

        <input
          type="text"
          name="username"
          placeholder="Enter username"
          required
          class="peer w-full border border-gray-300 rounded-xl px-4 py-2 text-sm sm:text-base
          focus:outline-none focus:ring-2 focus:ring-amber-400
          invalid:border-red-500"
        />

        <p class="hidden peer-invalid:block text-red-500 text-sm mt-1">
          Username is required *
        </p>
      </div>

      <!-- Email -->
      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-1">
          Email
        </label>

        <input
          type="email"
          name="email"
          placeholder="Enter email"
          required
          class="peer w-full border border-gray-300 rounded-xl px-4 py-2 text-sm sm:text-base
          focus:outline-none focus:ring-2 focus:ring-amber-400
          invalid:border-red-500"
        />

        <p class="hidden peer-invalid:block text-red-500 text-sm mt-1">
          Email is required *
        </p>
      </div>

      <!-- Password -->
      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-1">
          Password
        </label>

        <input
          type="password"
          name="password"
          placeholder="Enter password"
          required
          class="peer w-full border border-gray-300 rounded-xl px-4 py-2 text-sm sm:text-base
          focus:outline-none focus:ring-2 focus:ring-amber-400
          invalid:border-red-500"
        />

        <p class="hidden peer-invalid:block text-red-500 text-sm mt-1">
          Password is required *
        </p>
      </div>

      <!-- Submit Button -->
      <button
        type="submit"
        class="w-full bg-amber-500 hover:bg-amber-600
        text-white py-2.5 sm:py-3 rounded-xl
        font-semibold text-sm sm:text-base
        transition duration-200 cursor-pointer"
      >
        Sign Up
      </button>

      <!-- Login Link -->
      <p class="text-center text-sm text-gray-600">

        Already have an account?

        <a
          href="/login"
          class="text-amber-500 font-semibold hover:underline"
        >
          Login
        </a>

      </p>

    </form>

  </div>

</section>