<% layout("/layouts/boilerplate") %>

<div class="max-w-7xl mx-auto px-4 py-10">

    <!-- Title -->
    <h1 class="text-3xl md:text-4xl font-bold text-center mb-10">
        User Dashboard
    </h1>


    <!-- Main Grid -->
    <div class="grid lg:grid-cols-3 gap-8">

        <!-- PROFILE CARD -->
        <div class="bg-white shadow-lg rounded-2xl p-8 text-center">

            <img 
            src="<%= user.image && user.image.url ? user.image.url : '/assets/user.png' %>"
            class="w-28 h-28 rounded-full mx-auto border-4 border-amber-500 object-cover">

            <h2 class="text-xl font-bold mt-4">
                <%= user.username %>
            </h2>

            <p class="text-gray-500 text-sm">
                <%= user.email %>
            </p>

            <p class="text-gray-400 text-sm mt-2">
                Member since :
                <%= user._id.getTimestamp().toDateString() %>
            </p>

            <a href="/profile/edit"
            class="inline-block mt-5 bg-amber-500 hover:bg-amber-600 text-white px-5 py-2 rounded-lg transition">

                Edit Profile

            </a>

        </div>



        <!-- STATS + ACTIONS -->
        <div class="lg:col-span-2 space-y-8">

            <!-- Stats -->
            <div class="grid sm:grid-cols-2 gap-6">

                <!-- BOOKINGS -->
                <div class="bg-white shadow-lg rounded-xl p-6 text-center hover:shadow-xl transition">

                    <h2 class="text-4xl font-bold text-amber-500">
                        <%= totalBookings %>
                    </h2>

                    <p class="text-gray-500 mt-2">
                        Total Bookings
                    </p>

                    <a href="/my-bookings"
                    class="inline-block mt-4 bg-amber-500 hover:bg-amber-600 text-white px-4 py-2 rounded-lg">

                        View Bookings

                    </a>

                </div>


                <!-- TRIPS -->
                <div class="bg-white shadow-lg rounded-xl p-6 text-center hover:shadow-xl transition">

                    <h2 class="text-4xl font-bold text-blue-500">
                        <%= totalTrips %>
                    </h2>

                    <p class="text-gray-500 mt-2">
                        Trips Added
                    </p>

                    <a href="/tripnests/new"
                    class="inline-block mt-4 bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded-lg">

                        Add Trip

                    </a>

                </div>

            </div>

            <!-- ACTIONS -->
            <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-6">

                <a href="/my-bookings"
                class="bg-white shadow-md hover:shadow-xl transition p-6 rounded-xl text-center">

                    <h3 class="text-lg font-semibold">
                        My Bookings
                    </h3>

                    <p class="text-gray-500 text-sm mt-1">
                        See all your bookings
                    </p>

                </a>


                <a href="/tripnests"
                class="bg-white shadow-md hover:shadow-xl transition p-6 rounded-xl text-center">

                    <h3 class="text-lg font-semibold">
                        Explore Trips
                    </h3>

                    <p class="text-gray-500 text-sm mt-1">
                        Find new destinations
                    </p>

                </a>


                <a href="/tripnests/new"
                class="bg-white shadow-md hover:shadow-xl transition p-6 rounded-xl text-center">

                    <h3 class="text-lg font-semibold">
                        Add New Trip
                    </h3>

                    <p class="text-gray-500 text-sm mt-1">
                        Create a new listing
                    </p>

                </a>

            </div>

        </div>

    </div>

</div>