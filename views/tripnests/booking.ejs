<% layout("/layouts/boilerplate") %>

<div class="max-w-xl mx-auto mt-10 bg-white p-6 rounded-2xl shadow-lg">

<h1 class="text-2xl font-bold mb-6 text-center">

Book <%= tripNest.title %>

</h1>

<form action="/tripnests/<%= tripNest._id %>/booking" method="POST">

<div class="mb-4">

<label class="block mb-1 font-semibold">

Check In

</label>

<input
type="date"
name="checkIn"
required
class="w-full border rounded-lg px-3 py-2">

</div>


<div class="mb-4">

<label class="block mb-1 font-semibold">

Check Out

</label>

<input
type="date"
name="checkOut"
required
class="w-full border rounded-lg px-3 py-2">

</div>


<button
class="w-full bg-amber-500 hover:bg-amber-600 text-white py-2 rounded-xl">

Confirm Booking

</button>

</form>

</div>