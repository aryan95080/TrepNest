<% layout("/layouts/boilerplate")%>

<!-- Hero -->
<section class="bg-gradient-to-br from-gray-50 to-gray-100 py-20 px-4 text-center">
  <div class="max-w-5xl mx-auto">
    <span class="inline-flex items-center px-3 py-1 rounded-full text-sm bg-amber-100 text-amber-700 mb-4">
      <i class="fa-solid fa-shield-halved mr-2"></i> Updated: March 27, 2026
    </span>

    <h1 class="text-4xl md:text-5xl font-bold text-gray-800 mb-4">
      Privacy Policy 🔒
    </h1>

    <p class="text-lg text-gray-600">
      Your privacy matters. Learn how TripNest protects your information.
    </p>

    <!-- Quick Search -->
    <div class="mt-6 max-w-md mx-auto">
      <input
        id="policySearch"
        type="text"
        placeholder="Search policy..."
        class="w-full px-4 py-3 rounded-lg border focus:ring-2 focus:ring-amber-400 outline-none"
      >
    </div>

  </div>
</section>


<!-- Main -->
<section class="py-16 px-4 bg-white">
<div class="max-w-5xl mx-auto">


<!-- Sticky Navigation -->
<div class="bg-white border rounded-xl shadow-sm p-4 mb-8 sticky top-20 z-10">

<div class="flex flex-wrap gap-2 justify-center">

<% const navItems = [
{id:"info",name:"Info",icon:"fa-database"},
{id:"usage",name:"Usage",icon:"fa-chart-line"},
{id:"cookies",name:"Cookies",icon:"fa-cookie-bite"},
{id:"security",name:"Security",icon:"fa-shield-virus"},
{id:"thirdparty",name:"Partners",icon:"fa-share-nodes"},
{id:"rights",name:"Rights",icon:"fa-scale-balanced"},
{id:"updates",name:"Updates",icon:"fa-clock-rotate-left"},
{id:"contact",name:"Contact",icon:"fa-headset"}
]; %>

<% navItems.forEach(item=>{ %>

<button
onclick="scrollToSection('<%=item.id%>')"
class="nav-btn px-4 py-2 rounded-lg text-sm font-medium bg-gray-100 text-gray-700 hover:bg-amber-500 hover:text-white transition flex items-center gap-2">

<i class="fa-solid <%=item.icon%>"></i>
<span><%=item.name%></span>

</button>

<% }) %>

</div>
</div>


<!-- Content -->
<div class="bg-white border rounded-2xl shadow-lg overflow-hidden">

<div class="bg-amber-50 px-6 py-3 border-b">
<p class="text-sm text-amber-800">
<i class="fa-regular fa-calendar mr-2"></i>
<strong>Effective:</strong> March 27, 2026
</p>
</div>

<div class="p-6 md:p-8 space-y-10">

<!-- Section -->
<div id="info" class="policy-section">
<h2 class="section-title">1. Information We Collect</h2>
<p class="section-text">
Name, email, profile image, travel preferences, booking data, IP address, and cookies.
</p>
</div>


<div id="usage" class="policy-section">
<h2 class="section-title">2. How We Use Data</h2>
<p class="section-text">
We personalize experiences, manage bookings, send updates, and improve website functionality.
</p>
</div>


<div id="cookies" class="policy-section">
<h2 class="section-title">3. Cookies</h2>
<p class="section-text">
TripNest uses essential and analytics cookies to improve performance.
</p>
</div>


<div id="security" class="policy-section">
<h2 class="section-title">4. Data Security</h2>
<p class="section-text">
We use SSL encryption, secure servers, and security monitoring.
</p>
</div>


<div id="thirdparty" class="policy-section">
<h2 class="section-title">5. Third Party Services</h2>
<p class="section-text">
We may integrate Google Maps, payment gateways and analytics tools.
</p>
</div>


<div id="rights" class="policy-section">
<h2 class="section-title">6. Your Rights</h2>
<p class="section-text">
Users can request access, correction, deletion or export of their data.
</p>
</div>


<div id="updates" class="policy-section">
<h2 class="section-title">7. Policy Updates</h2>
<p class="section-text">
This policy may change over time. Updated version will be posted here.
</p>
</div>


<div id="contact" class="policy-section">
<h2 class="section-title">8. Contact</h2>

<p class="section-text">
For privacy concerns contact:
</p>

<a href="mailto:support@tripnest.com"
class="text-amber-600 font-semibold hover:underline">

support@tripnest.com

</a>

</div>

</div>
</div>


<!-- Buttons -->
<div class="flex justify-center gap-4 mt-8">

<button
onclick="window.print()"
class="px-5 py-2 border rounded-lg hover:bg-gray-100">

<i class="fa-solid fa-print mr-1"></i>
Print

</button>

<button
onclick="downloadPolicy()"
class="px-5 py-2 bg-amber-500 text-white rounded-lg hover:bg-amber-600">

<i class="fa-solid fa-download mr-1"></i>
Download

</button>

</div>

</div>
</section>


<script>

function scrollToSection(id){
const el=document.getElementById(id)

window.scrollTo({
top:el.offsetTop-200,
behavior:'smooth'
})
}


/* SEARCH */

document.getElementById("policySearch").addEventListener("keyup",function(){

let value=this.value.toLowerCase()
let sections=document.querySelectorAll(".policy-section")

sections.forEach(sec=>{

let text=sec.innerText.toLowerCase()

if(text.includes(value)){
sec.style.display="block"
}
else{
sec.style.display="none"
}

})

})


/* DOWNLOAD */

function downloadPolicy(){

const content=document.querySelector(".policy-section").parentElement.innerText

const blob=new Blob([content],{type:"text/plain"})

const link=document.createElement("a")

link.href=URL.createObjectURL(blob)

link.download="tripnest-privacy-policy.txt"

link.click()

}

</script>


<style>

.section-title{
font-size:22px;
font-weight:700;
color:#1f2937;
margin-bottom:8px;
}

.section-text{
color:#4b5563;
font-size:15px;
line-height:1.6;
}

.policy-section{
scroll-margin-top:100px;
}

</style>