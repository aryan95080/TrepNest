<% layout("/layouts/boilerplate") %>

<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

  <!-- Heading -->
  <div class="text-center mb-14">
    <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold text-gray-800">
      About TripNest
    </h1>
    <p class="text-gray-500 mt-3 text-base sm:text-lg">
      Find your perfect stay anywhere in the world 🌍
    </p>
  </div>


  <!-- Intro Section -->
  <div class="grid md:grid-cols-2 gap-10 items-center mb-20">

    <img 
      src="https://images.unsplash.com/photo-1505693416388-ac5ce068fe85"
      class="rounded-2xl shadow-xl w-full h-[250px] sm:h-[350px] object-cover"
    >

    <div>

      <h2 class="text-2xl sm:text-3xl font-bold mb-4 text-gray-800">
        Welcome to TripNest
      </h2>

      <p class="text-gray-600 text-sm sm:text-base leading-relaxed mb-4">
        TripNest is a travel accommodation platform where users can explore
        amazing places to stay across the world. Whether you want a cozy
        mountain cabin, a beachside villa, or a modern city apartment,
        TripNest helps you discover unique stays easily.
      </p>

      <p class="text-gray-600 text-sm sm:text-base leading-relaxed">
        Our goal is to make travel planning simple and enjoyable by connecting
        travelers with hosts who offer memorable experiences.
      </p>

    </div>

  </div>


  <!-- Features -->
  <div class="mb-20">

    <h2 class="text-2xl sm:text-3xl font-bold text-center text-gray-800 mb-10">
      ✨ Features
    </h2>

    <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-8">

      <!-- Feature 1 -->
      <div class="bg-white shadow-md hover:shadow-xl transition p-6 rounded-2xl text-center">

        <h3 class="text-lg sm:text-xl font-semibold mb-3">
          🌍 Explore Destinations
        </h3>

        <p class="text-gray-600 text-sm sm:text-base">
          Discover beautiful places around the world with detailed listings.
        </p>

      </div>


      <!-- Feature 2 -->
      <div class="bg-white shadow-md hover:shadow-xl transition p-6 rounded-2xl text-center">

        <h3 class="text-lg sm:text-xl font-semibold mb-3">
          📝 User Reviews
        </h3>

        <p class="text-gray-600 text-sm sm:text-base">
          Read reviews from other travelers and share your own experiences.
        </p>

      </div>


      <!-- Feature 3 -->
      <div class="bg-white shadow-md hover:shadow-xl transition p-6 rounded-2xl text-center">

        <h3 class="text-lg sm:text-xl font-semibold mb-3">
          🗺 Location Map
        </h3>

        <p class="text-gray-600 text-sm sm:text-base">
          View the exact location of listings using an interactive map.
        </p>

      </div>

    </div>

  </div>


  <!-- Mission -->
  <div class="bg-gray-100 p-8 sm:p-12 rounded-2xl text-center mb-20">

    <h2 class="text-2xl sm:text-3xl font-bold text-gray-800 mb-4">
      Our Mission
    </h2>

    <p class="text-gray-600 max-w-3xl mx-auto text-sm sm:text-base leading-relaxed">
      Our mission is to make travel easier and more accessible by helping
      people discover unique accommodations and unforgettable experiences
      wherever they go.
    </p>

  </div>


  <!-- Developer -->
  <div class="text-center">

    <h2 class="text-2xl sm:text-3xl font-bold text-gray-800 mb-8">
      👨‍💻 Developer
    </h2>

    <div class="bg-white shadow-lg hover:shadow-xl transition rounded-2xl p-8 max-w-md mx-auto">

      <h3 class="text-lg sm:text-xl font-semibold">
        Amit Kumar
      </h3>

      <p class="text-gray-500 mt-2">
        Full Stack Developer
      </p>

      <p class="text-gray-600 text-sm sm:text-base mt-4">
        Built TripNest using Node.js, Express, MongoDB, Tailwind CSS,
        Cloudinary, and OpenStreetMap.
      </p>

    </div>

  </div>

</section>