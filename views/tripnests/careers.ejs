<% layout("/layouts/boilerplate")%>

<section class="bg-gray-50 py-16 px-4">
  <div class="max-w-7xl mx-auto text-center">

    <h1 class="text-4xl font-bold text-gray-800 mb-4">
      Join Our Team ✈️
    </h1>

    <p class="text-gray-600 max-w-2xl mx-auto">
      At <span class="text-amber-500 font-semibold">TripNest</span> we are building the future of travel experiences.
      Join us and help travelers discover the world.
    </p>

  </div>
</section>


<!-- WHY WORK WITH US -->
<section class="py-16 px-4">
  <div class="max-w-7xl mx-auto">

    <h2 class="text-3xl font-bold text-center mb-12">
      Why Work With Us
    </h2>

    <div class="grid md:grid-cols-3 gap-8 text-center">

      <div class="bg-white shadow-md p-6 rounded-xl">
        <div class="text-4xl mb-3">🌍</div>
        <h3 class="font-semibold text-lg mb-2">Travel Culture</h3>
        <p class="text-gray-600 text-sm">
          Work in an environment that celebrates exploration and adventure.
        </p>
      </div>

      <div class="bg-white shadow-md p-6 rounded-xl">
        <div class="text-4xl mb-3">🚀</div>
        <h3 class="font-semibold text-lg mb-2">Growth</h3>
        <p class="text-gray-600 text-sm">
          Build your career with opportunities for learning and leadership.
        </p>
      </div>

      <div class="bg-white shadow-md p-6 rounded-xl">
        <div class="text-4xl mb-3">🤝</div>
        <h3 class="font-semibold text-lg mb-2">Team Work</h3>
        <p class="text-gray-600 text-sm">
          Collaborate with passionate people who love building amazing products.
        </p>
      </div>

    </div>
  </div>
</section>


<!-- OPEN POSITIONS -->
<section class="bg-gray-100 py-16 px-4">
  <div class="max-w-6xl mx-auto">

    <h2 class="text-3xl font-bold text-center mb-12">
      Open Positions
    </h2>

    <div class="space-y-6">

      <!-- Job 1 -->
      <div class="bg-white shadow-md rounded-xl p-6 flex flex-col md:flex-row md:items-center md:justify-between">

        <div>
          <h3 class="text-xl font-semibold">Frontend Developer</h3>
          <p class="text-gray-500 text-sm">Remote • Full Time</p>
        </div>

        <a href="#"
          class="mt-4 md:mt-0 bg-amber-500 hover:bg-amber-600 text-white px-6 py-2 rounded-full transition">
          Apply Now
        </a>

      </div>


      <!-- Job 2 -->
      <div class="bg-white shadow-md rounded-xl p-6 flex flex-col md:flex-row md:items-center md:justify-between">

        <div>
          <h3 class="text-xl font-semibold">Backend Developer</h3>
          <p class="text-gray-500 text-sm">Remote • Full Time</p>
        </div>

        <a href="#"
          class="mt-4 md:mt-0 bg-amber-500 hover:bg-amber-600 text-white px-6 py-2 rounded-full transition">
          Apply Now
        </a>

      </div>


      <!-- Job 3 -->
      <div class="bg-white shadow-md rounded-xl p-6 flex flex-col md:flex-row md:items-center md:justify-between">

        <div>
          <h3 class="text-xl font-semibold">Travel Content Writer</h3>
          <p class="text-gray-500 text-sm">Part Time • Remote</p>
        </div>

        <a href="#"
          class="mt-4 md:mt-0 bg-amber-500 hover:bg-amber-600 text-white px-6 py-2 rounded-full transition">
          Apply Now
        </a>

      </div>


      <!-- Job 4 -->
      <div class="bg-white shadow-md rounded-xl p-6 flex flex-col md:flex-row md:items-center md:justify-between">

        <div>
          <h3 class="text-xl font-semibold">UI / UX Designer</h3>
          <p class="text-gray-500 text-sm">Hybrid • Full Time</p>
        </div>

        <a href="#"
          class="mt-4 md:mt-0 bg-amber-500 hover:bg-amber-600 text-white px-6 py-2 rounded-full transition">
          Apply Now
        </a>

      </div>

    </div>

  </div>
</section>


<!-- CTA -->
<section class="py-16 px-4 text-center">
  <div class="max-w-3xl mx-auto">

    <h2 class="text-3xl font-bold mb-4">
      Don't see a role that fits?
    </h2>

    <p class="text-gray-600 mb-6">
      We’re always looking for talented people. Send us your resume and we’ll keep you in mind.
    </p>

    <a href="mailto:careers@tripnest.com"
      class="bg-gray-900 text-white px-8 py-3 rounded-full hover:bg-gray-700 transition">
      Send Resume
    </a>

  </div>
</section>

