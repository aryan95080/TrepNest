<% layout("/layouts/boilerplate") %>

<%
const categories = [
{name:"All", icon:"fa-solid fa-globe", value:"all"},
{name:"trending", icon:"fa-solid fa-fire", value:"trending"},
{name:"Unique", icon:"fa-solid fa-cubes-stacked", value:"unique"},
 {name:"Cities", icon:"fa-city", value:"cities"},
 {name:"Mountains", icon:"fa-mountain", value:"mountains"},
 {name:"Castles", icon:"fa-fort-awesome", value:"castles"},
 {name:"Pools", icon:"fa-person-swimming", value:"pools"},
 {name:"Camping", icon:"fa-campground", value:"camping"},
 {name:"Farms", icon:"fa-cow", value:"farms"},
 {name:"Arctic", icon:"fa-snowflake", value:"arctic"},
 {name:"Beach", icon:"fa-umbrella-beach", value:"beach"},
 {name:"Luxury", icon:"fa-gem", value:"luxury"},
 {name:"Treehouse", icon:"fa-tree", value:"treehouse"}
];
%>


<!-- FILTER BAR -->
<section class="w-full px-5 md:px-10 mt-6 flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">

  <!-- Categories -->
  <div class="flex overflow-x-auto gap-8 py-3 w-full scrollbar-hide">

    <% categories.forEach(cat => { %>

      <a href="/tripnests?category=<%= cat.value %>"
        class="flex flex-col items-center text-gray-600 hover:text-black transition min-w-[70px]">

        <i class="fa-solid <%= cat.icon %> text-xl hover:text-amber-300"></i>

        <p class="text-xs mt-1"><%= cat.name %></p>

      </a>

    <% }) %>

  </div>


  <!-- Price + Filter -->
  <div class="flex justify-center lg:justify-end gap-4">

    <select onchange="filterPrice(this.value)"
      class="border px-4 py-2 rounded-xl text-sm hover:bg-gray-100">

      <option value="">Sort by Price</option>
      <option value="low">Low → High</option>
      <option value="high">High → Low</option>

    </select>


    <button
      class="flex items-center gap-2 px-4 py-2 border rounded-xl hover:bg-gray-100 transition shadow-sm">

      <i class="fa-solid fa-sliders"></i>
      Filters

    </button>

  </div>

</section>



<!-- PAGE TITLE -->
<h1 class="text-2xl md:text-3xl font-bold text-center text-gray-800 my-8">
  All TripNests
</h1>



<!-- CREATE BUTTON -->
<div class="mx-4 mb-4">

  <button onclick="window.location.href='/tripnests/new'"
    class="px-6 py-2 bg-amber-500 text-white rounded-xl font-medium hover:bg-amber-600 transition shadow">

    Create New TripNest

  </button>

</div>



<!-- TRIPNEST CARDS -->
<section class="bg-gray-100 min-h-screen px-4 py-6">

  <div class="grid gap-6
    grid-cols-1
    sm:grid-cols-2
    md:grid-cols-3
    lg:grid-cols-4
    xl:grid-cols-5
    max-w-7xl mx-auto">

    <% allTripNests.forEach(tripNest => { %>

      <div
        class="bg-white rounded-2xl shadow hover:shadow-lg transition overflow-hidden flex flex-col">

        <img src="<%= tripNest.image.url %>"
          class="h-48 w-full object-cover hover:scale-105 transition duration-300">


        <div class="p-4 flex flex-col flex-grow">

          <h2 class="text-lg font-semibold text-gray-800">
            <%= tripNest.title %>
          </h2>


          <p class="text-xs text-gray-500 mb-1">
            📍 <%= tripNest.location %>, <%= tripNest.country %>
          </p>


          <p class="text-sm text-gray-600 mb-3 line-clamp-2">
            <%= tripNest.description %>
          </p>


          <p class="text-base font-bold text-amber-600 mt-auto">
            ₹ <%= tripNest.price.toLocaleString("en-IN") %>
            <span class="text-xs text-gray-500"> / night</span>
          </p>


          <button
            onclick="window.location.href='/tripnests/<%= tripNest._id %>'"
            class="mt-3 bg-amber-500 text-white py-2 rounded-lg hover:bg-amber-600 transition text-sm">

            Explore Now

          </button>

        </div>

      </div>

    <% }) %>

  </div>

</section>