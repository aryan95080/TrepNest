    <!-- Blog Card 1 -->
    <div class="bg-white shadow-md rounded-xl overflow-hidden hover:shadow-xl transition">
      <img src="/images/blog1.jpg" class="w-full h-52 object-cover">
      <div class="p-6">
        <h3 class="text-xl font-semibold mb-2">
          Top 10 Hidden Places in India
        </h3>
        <p class="text-gray-600 text-sm mb-4">
          Discover some of the most beautiful hidden destinations in India that travelers often miss.
        </p>
        <a href="#" class="text-amber-500 font-medium hover:underline">
          Read More →
        </a>
      </div>
    </div>


