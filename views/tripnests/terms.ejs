<% layout("/layouts/boilerplate")%>

<!-- Hero -->
<section class="bg-gradient-to-br from-gray-50 to-gray-100 py-16 px-4 text-center">
  <div class="max-w-5xl mx-auto">
    <span class="inline-flex items-center px-3 py-1 rounded-full text-sm bg-amber-100 text-amber-700 mb-3">
      <i class="fa-solid fa-scale-balanced mr-2"></i> Updated: March 27, 2026
    </span>
    <h1 class="text-4xl font-bold text-gray-800 mb-2">Terms of Service 📜</h1>
    <p class="text-gray-600">Please read these terms before using TripNest.</p>
  </div>
</section>

<!-- Content -->
<section class="py-12 px-4 bg-white">
  <div class="max-w-5xl mx-auto">
    
    <!-- Quick Nav -->
    <div class="bg-white border rounded-xl p-3 mb-6 sticky top-20 z-10 flex flex-wrap gap-2 justify-center">
      <% const items = [
        "Acceptance", "Services", "Accounts", "Bookings", "Payments",
        "Cancellation", "Conduct", "Liability", "Updates", "Contact"
      ]; %>
      <% items.forEach((item, i) => { %>
        <button onclick="scrollTo('s<%= i %>')" 
                class="nav-btn px-3 py-1.5 rounded-lg text-sm bg-gray-100 hover:bg-amber-500 hover:text-white transition">
          <%= item %>
        </button>
      <% }); %>
    </div>
    
    <!-- Terms Container -->
    <div class="bg-white border rounded-2xl shadow-md overflow-hidden">
      <div class="bg-amber-50 px-5 py-2 border-b">
        <p class="text-sm text-amber-800"><i class="fa-regular fa-calendar-alt mr-2"></i>Effective: March 27, 2026</p>
      </div>
      
      <div class="p-6 space-y-6">
        
        <% const terms = [
          { icon: "fa-check-circle", title: "1. Acceptance of Terms", text: "By using TripNest, you agree to these Terms. If you disagree, please don't use our services." },
          { icon: "fa-briefcase", title: "2. Our Services", text: "We provide travel planning, booking services, and destination guides as an intermediary between users and providers." },
          { icon: "fa-user", title: "3. User Accounts", text: "You must be 18+ to create an account. You're responsible for account security and all activities under it." },
          { icon: "fa-calendar-check", title: "4. Bookings", text: "All bookings are subject to availability. Prices may change based on demand and provider policies." },
          { icon: "fa-credit-card", title: "5. Payments", text: "Full payment required at booking. We accept major credit cards. Additional fees may apply." },
          { icon: "fa-ban", title: "6. Cancellation", text: "Most bookings are refundable up to 7 days before travel. Non-refundable bookings are clearly marked." },
          { icon: "fa-gavel", title: "7. User Conduct", text: "Don't misuse services, post false info, or violate laws. We may terminate accounts for violations." },
          { icon: "fa-shield", title: "8. Liability", text: "We're not liable for third-party failures or damages beyond our control. Liability limited to amount paid." },
          { icon: "fa-pen", title: "9. Updates", text: "Terms may be updated. Continued use means acceptance. Material changes will be notified." },
          { icon: "fa-headset", title: "10. Contact", text: "Questions? Email us at legal@tripnest.com. Response within 24-48 hours." }
        ]; %>
        
        <% terms.forEach((term, idx) => { %>
          <div id="s<%= idx %>" class="scroll-target flex gap-3">
            <div class="w-9 h-9 bg-amber-100 rounded-lg flex items-center justify-center flex-shrink-0">
              <i class="fa-solid <%= term.icon %> text-amber-600 text-sm"></i>
            </div>
            <div>
              <h2 class="text-lg font-bold text-gray-800 mb-1"><%= term.title %></h2>
              <p class="text-gray-600 text-sm"><%= term.text %></p>
            </div>
          </div>
        <% }); %>
        
        <!-- Footer -->
        <div class="border-t pt-3 text-center text-xs text-gray-500">
          <i class="fa-regular fa-handshake text-amber-500"></i> Thank you for choosing TripNest
        </div>
      </div>
    </div>
    
    <!-- Buttons -->
    <div class="flex justify-center gap-3 mt-6">
      <button onclick="window.print()" class="px-4 py-2 border rounded-lg text-sm hover:bg-gray-50">
        <i class="fa-solid fa-print mr-1"></i>Print
      </button>
      <button onclick="downloadTerms()" class="px-4 py-2 bg-amber-500 text-white rounded-lg text-sm hover:bg-amber-600">
        <i class="fa-solid fa-download mr-1"></i>Download
      </button>
    </div>
  </div>
</section>

<script>
  function scrollTo(id) {
    const el = document.getElementById(id);
    if (el) {
      window.scrollTo({ top: el.offsetTop - 100, behavior: 'smooth' });
      el.style.backgroundColor = '#fef3c7';
      setTimeout(() => el.style.backgroundColor = '', 500);
    }
  }
  
  // Active nav highlight
  const sections = Array.from({length: 10}, (_, i) => `s${i}`);
  const btns = document.querySelectorAll('.nav-btn');
  
  function updateActive() {
    let current = '';
    const scrollPos = window.scrollY + 200;
    sections.forEach(id => {
      const el = document.getElementById(id);
      if (el && scrollPos >= el.offsetTop) current = id;
    });
    btns.forEach((btn, i) => {
      if (`s${i}` === current) {
        btn.classList.add('bg-amber-500', 'text-white');
        btn.classList.remove('bg-gray-100');
      } else {
        btn.classList.remove('bg-amber-500', 'text-white');
        btn.classList.add('bg-gray-100');
      }
    });
  }
  
  let ticking = false;
  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(() => { updateActive(); ticking = false; });
      ticking = true;
    }
  });
  
  function downloadTerms() {
    const content = document.querySelector('.bg-white.border.rounded-2xl').cloneNode(true);
    const html = `<!DOCTYPE html><html><head><title>Terms of Service</title><meta charset="UTF-8"><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css"><style>body{font-family:Arial,sans-serif;padding:40px;max-width:900px;margin:0 auto}.nav-btn,button,.sticky{display:none}</style></head><body>${content.outerHTML}</body></html>`;
    const blob = new Blob([html], { type: 'text/html' });
    const link = document.createElement('a');
    link.href = URL.createObjectURL(blob);
    link.download = 'terms-of-service.html';
    link.click();
    URL.revokeObjectURL(link.href);
  }
  
  setTimeout(updateActive, 100);
</script>

<style>
  .scroll-target { scroll-margin-top: 100px; }
  .nav-btn { transition: all 0.2s; cursor: pointer; }
  @media print { .sticky, button { display: none !important; } }
</style>