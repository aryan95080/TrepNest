<% layout("/layouts/boilerplate") %>

<section class="min-h-screen flex items-center justify-center bg-gray-100 px-4 py-10">

<div class="w-full max-w-2xl bg-white rounded-2xl shadow-lg p-6 md:p-10">

<h1 class="text-2xl md:text-3xl font-bold text-center text-gray-800 mb-8">
Edit TripNest
</h1>

<form
action="/tripnests/<%= tripNest._id %>?_method=PUT"
method="POST"
enctype="multipart/form-data"
class="space-y-6">

<!-- TITLE -->
<div>

<label class="form-label">
Title
</label>

<input
type="text"
name="tripnest[title]"
value="<%= tripNest.title %>"
required
class="input-field peer"/>

<p class="error-text">
Title is required *
</p>

</div>


<!-- DESCRIPTION -->
<div>

<label class="form-label">
Description
</label>

<textarea
name="tripnest[description]"
rows="4"
required
class="input-field peer"><%= tripNest.description %></textarea>

<p class="error-text">
Description is required *
</p>

</div>


<!-- IMAGE -->
<div>

<label class="form-label">
Upload New Image
</label>

<input
type="file"
name="image"
accept="image/*"
class="file-input"/>

<!-- IMAGE PREVIEW -->

<div class="mt-3">

<img
src="<%= tripNest.image?.url || 'https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?w=1200' %>"
alt="TripNest Image"
class="preview-img">

</div>

</div>


<!-- PRICE -->
<div>

<label class="form-label">
Price (₹ per night)
</label>

<input
type="number"
name="tripnest[price]"
value="<%= tripNest.price %>"
min="0"
required
class="input-field peer"/>

<p class="error-text">
Valid price required *
</p>

</div>


<!-- LOCATION + COUNTRY -->
<div class="grid grid-cols-1 md:grid-cols-2 gap-4">

<div>

<label class="form-label">
Location
</label>

<input
type="text"
name="tripnest[location]"
value="<%= tripNest.location %>"
required
class="input-field"/>

</div>

<div>

<label class="form-label">
Country
</label>

<input
type="text"
name="tripnest[country]"
value="<%= tripNest.country %>"
required
class="input-field"/>

</div>

</div>


<!-- BUTTON -->

<button
type="submit"
class="submit-btn">

Update TripNest

</button>

</form>

</div>

</section>



<style>

/* LABEL */

.form-label{
display:block;
font-size:14px;
font-weight:600;
color:#374151;
margin-bottom:6px;
}


/* INPUT */

.input-field{
width:100%;
border:1px solid #d1d5db;
border-radius:12px;
padding:10px 14px;
font-size:14px;
outline:none;
transition:0.2s;
}

.input-field:focus{
border-color:#f59e0b;
box-shadow:0 0 0 2px rgba(245,158,11,0.25);
}


/* ERROR TEXT */

.error-text{
display:none;
font-size:12px;
color:#ef4444;
margin-top:4px;
}

.peer:invalid + .error-text{
display:block;
}


/* FILE INPUT */

.file-input{
width:100%;
padding:10px;
border:1px dashed #9ca3af;
border-radius:10px;
background:#f9fafb;
cursor:pointer;
}

.file-input:hover{
background:#f3f4f6;
}


/* IMAGE PREVIEW */

.preview-img{
width:100%;
height:180px;
object-fit:cover;
border-radius:12px;
border:1px solid #e5e7eb;
}


/* BUTTON */

.submit-btn{
width:100%;
background:#f59e0b;
color:white;
padding:12px;
border-radius:12px;
font-weight:600;
font-size:15px;
transition:0.2s;
}

.submit-btn:hover{
background:#d97706;
}

</style>