<% layout("/layouts/boilerplate")%>

<!-- Hero -->
<section class="bg-gradient-to-br from-gray-50 to-gray-100 py-16 px-4 text-center">
  <div class="max-w-5xl mx-auto">
    <span class="inline-flex items-center px-3 py-1 rounded-full text-sm bg-amber-100 text-amber-700 mb-3">
      <i class="fa-solid fa-cookie-bite mr-2"></i> Updated: March 27, 2026
    </span>
    <h1 class="text-4xl font-bold text-gray-800 mb-2">Cookie Policy 🍪</h1>
    <p class="text-gray-600">Learn how we use cookies to improve your experience on TripNest.</p>
  </div>
</section>

<!-- Content -->
<section class="py-12 px-4 bg-white">
  <div class="max-w-5xl mx-auto">
    
    <!-- Quick Nav -->
    <div class="bg-white border rounded-xl p-3 mb-6 sticky top-20 z-10 flex flex-wrap gap-2 justify-center">
      <% const items = ["What Are Cookies", "How We Use", "Types", "Your Control", "Consent", "Updates", "Contact"]; %>
      <% items.forEach((item, i) => { %>
        <button onclick="scrollTo('s<%= i %>')" 
                class="nav-btn px-3 py-1.5 rounded-lg text-sm bg-gray-100 hover:bg-amber-500 hover:text-white transition">
          <%= item %>
        </button>
      <% }); %>
    </div>
    
    <!-- Cookie Policy Container -->
    <div class="bg-white border rounded-2xl shadow-md overflow-hidden">
      <div class="bg-amber-50 px-5 py-2 border-b">
        <p class="text-sm text-amber-800"><i class="fa-regular fa-calendar-alt mr-2"></i>Effective: March 27, 2026</p>
      </div>
      
      <div class="p-6 space-y-6">
        
        <% const policies = [
          { icon: "fa-circle-info", title: "1. What Are Cookies?", text: "Cookies are small text files stored on your device when you visit websites. They help us remember your preferences and improve your experience." },
          { icon: "fa-chart-line", title: "2. How We Use Cookies", text: "We use cookies to analyze site traffic, remember your preferences, personalize content, and provide social media features." },
          { icon: "fa-list", title: "3. Types of Cookies We Use", text: "Essential (required for site function), Performance (analyze usage), Functional (remember preferences), and Targeting (deliver relevant ads)." },
          { icon: "fa-sliders-h", title: "4. Your Control", text: "You can manage cookies through browser settings. Disabling cookies may affect site functionality. Most browsers accept cookies by default." },
          { icon: "fa-check-circle", title: "5. Your Consent", text: "By using our website, you consent to our use of cookies. You can withdraw consent anytime by clearing cookies or changing browser settings." },
          { icon: "fa-clock-rotate-left", title: "6. Policy Updates", text: "We may update this policy periodically. Changes will be posted here with an updated effective date." },
          { icon: "fa-headset", title: "7. Contact Us", text: "Questions about cookies? Email us at privacy@tripnest.com. We'll respond within 24-48 hours." }
        ]; %>
        
        <% policies.forEach((policy, idx) => { %>
          <div id="s<%= idx %>" class="scroll-target flex gap-3">
            <div class="w-9 h-9 bg-amber-100 rounded-lg flex items-center justify-center flex-shrink-0">
              <i class="fa-solid <%= policy.icon %> text-amber-600 text-sm"></i>
            </div>
            <div>
              <h2 class="text-lg font-bold text-gray-800 mb-1"><%= policy.title %></h2>
              <p class="text-gray-600 text-sm"><%= policy.text %></p>
            </div>
          </div>
        <% }); %>
        
        <!-- Cookie Settings Button -->
        <div class="bg-gray-50 rounded-xl p-4 text-center border">
          <p class="text-sm text-gray-600 mb-3">Manage your cookie preferences</p>
          <button onclick="showCookieSettings()" class="px-5 py-2 bg-amber-500 text-white rounded-lg text-sm hover:bg-amber-600 transition">
            <i class="fa-solid fa-cookie mr-2"></i>Cookie Settings
          </button>
        </div>
        
        <!-- Footer -->
        <div class="border-t pt-3 text-center text-xs text-gray-500">
          <i class="fa-regular fa-shield text-amber-500"></i> We value your privacy
        </div>
      </div>
    </div>
    
    <!-- Buttons -->
    <div class="flex justify-center gap-3 mt-6">
      <button onclick="window.print()" class="px-4 py-2 border rounded-lg text-sm hover:bg-gray-50">
        <i class="fa-solid fa-print mr-1"></i>Print
      </button>
      <button onclick="downloadPolicy()" class="px-4 py-2 bg-amber-500 text-white rounded-lg text-sm hover:bg-amber-600">
        <i class="fa-solid fa-download mr-1"></i>Download
      </button>
    </div>
  </div>
</section>

<script>
  function scrollTo(id) {
    const el = document.getElementById(id);
    if (el) {
      window.scrollTo({ top: el.offsetTop - 100, behavior: 'smooth' });
      el.style.backgroundColor = '#fef3c7';
      setTimeout(() => el.style.backgroundColor = '', 500);
    }
  }
  
  function showCookieSettings() {
    alert("Cookie Preferences\n\nEssential Cookies: Always Active\nPerformance Cookies: Enabled\nFunctional Cookies: Enabled\nTargeting Cookies: Disabled\n\nYou can manage these in your browser settings.");
  }
  
  // Active nav highlight
  const sections = Array.from({length: 7}, (_, i) => `s${i}`);
  const btns = document.querySelectorAll('.nav-btn');
  
  function updateActive() {
    let current = '';
    const scrollPos = window.scrollY + 200;
    sections.forEach(id => {
      const el = document.getElementById(id);
      if (el && scrollPos >= el.offsetTop) current = id;
    });
    btns.forEach((btn, i) => {
      if (`s${i}` === current) {
        btn.classList.add('bg-amber-500', 'text-white');
        btn.classList.remove('bg-gray-100');
      } else {
        btn.classList.remove('bg-amber-500', 'text-white');
        btn.classList.add('bg-gray-100');
      }
    });
  }
  
  let ticking = false;
  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(() => { updateActive(); ticking = false; });
      ticking = true;
    }
  });
  
  function downloadPolicy() {
    const content = document.querySelector('.bg-white.border.rounded-2xl').cloneNode(true);
    const html = `<!DOCTYPE html><html><head><title>Cookie Policy</title><meta charset="UTF-8"><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css"><style>body{font-family:Arial,sans-serif;padding:40px;max-width:900px;margin:0 auto}.nav-btn,button,.sticky{display:none}</style></head><body>${content.outerHTML}</body></html>`;
    const blob = new Blob([html], { type: 'text/html' });
    const link = document.createElement('a');
    link.href = URL.createObjectURL(blob);
    link.download = 'cookie-policy.html';
    link.click();
    URL.revokeObjectURL(link.href);
  }
  
  setTimeout(updateActive, 100);
</script>

<style>
  .scroll-target { scroll-margin-top: 100px; }
  .nav-btn { transition: all 0.2s; cursor: pointer; }
  @media print { .sticky, button { display: none !important; } }
</style>